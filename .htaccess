Options -Indexes

#####################################
# PHP HANDLER (IMPORTANT)
# Ne pas forcer une version non supportée
# Géré directement via cPanel (MultiPHP Manager)
#####################################

# Si ton hébergement nécessite un handler explicite, utilise plutôt :
# AddHandler application/x-httpd-ea-php83 .php
# Sinon, laisse cPanel gérer PHP automatiquement

#####################################
# SECURITY - PROTECTION FICHIERS SENSIBLES
#####################################

# Bloquer les fichiers .env
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Bloquer fichiers sensibles
<FilesMatch "\.(sql|log|sh)$">
    Require all denied
</FilesMatch>

#####################################
# PROTECTION DOSSIERS BACKEND
#####################################

RewriteEngine On

RewriteRule ^(config|models|services|database|cron)/ - [F,L]

#####################################
# FRONT CONTROLLER (API / APP)
#####################################

# Ne pas réécrire si fichier ou dossier existe
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route tout vers index.php
RewriteRule ^ index.php [QSA,L]

#####################################
# SECURITY HEADERS
#####################################

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>